<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Horizontal bar -->
    <item android:bottom="80%" android:right="80%"
          android:left="0dp" android:top="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#00E5FF" />
        </shape>
    </item>
    <!-- Vertical bar -->
    <item android:right="80%" android:top="0dp"
          android:left="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#00E5FF" />
        </shape>
    </item>
</layer-list>

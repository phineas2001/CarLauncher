<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0C141F" />
        </shape>
    </item>
    <!-- Bottom border glow -->
    <item android:top="98%">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#0000E5FF"
                android:centerColor="#8800E5FF"
                android:endColor="#0000E5FF" />
        </shape>
    </item>
</layer-list>

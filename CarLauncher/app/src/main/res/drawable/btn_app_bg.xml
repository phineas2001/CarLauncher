<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#2200E5FF" />
                    <stroke android:width="1.5dp" android:color="#00E5FF" />
                    <corners android:radius="6dp" />
                </shape>
            </item>
            <!-- Inner glow lines top -->
            <item android:top="0dp" android:bottom="0dp">
                <shape android:shape="rectangle">
                    <solid android:color="#00000000" />
                    <stroke android:width="0.5dp" android:color="#4400E5FF" />
                    <corners android:radius="5dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#1500E5FF" />
            <stroke android:width="1.5dp" android:color="#00E5FF" />
            <corners android:radius="6dp" />
        </shape>
    </item>

    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#0D1520" />
                    <stroke android:width="1dp" android:color="#2200E5FF" />
                    <corners android:radius="6dp" />
                </shape>
            </item>
        </layer-list>
    </item>

</selector>
